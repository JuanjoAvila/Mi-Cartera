<?xml version="1.0" encoding="utf-8"?>
<!-- updatePeriodMillis=0: no hay refresco periódico del sistema; lo refrescan la web
     (plugin updateWidget) y el lector de notis de TR (saveMonth) cuando hay datos nuevos. -->
<appwidget-provider xmlns:android="http://schemas.android.com/apk/res/android"
    android:minWidth="250dp"
    android:minHeight="70dp"
    android:targetCellWidth="4"
    android:targetCellHeight="1"
    android:updatePeriodMillis="0"
    android:initialLayout="@layout/widget_micartera"
    android:resizeMode="horizontal|vertical"
    android:widgetCategory="home_screen"
    android:description="@string/widget_desc" />
